# Supabase API Settings
# (Used for database queries, file uploads & storage buckets)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Firebase API Settings
# (Used for user authentication & signup flows)
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=1:your_sender_id:web:your_app_id

# Hugging Face Inference API
# (Used for ML-powered sentiment analysis and content moderation)
# Get your free token at: https://huggingface.co/settings/tokens
EXPO_PUBLIC_HF_API_KEY=hf_your_token_here
